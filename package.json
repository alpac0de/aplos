  },
  "dependencies": {
    "@babel/core": "^7.29.7",
    "@rspack/cli": "^2.0.8",
    "@rspack/core": "^2.0.8",
    "@rspack/dev-server": "^2.0.3",
    "@rspack/plugin-html": "^0.5.8",
    "@rspack/plugin-react-refresh": "^2.0.2",
    "@swc/react-compiler": "^1.15.41",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "19.1.0-rc.3",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.2",
    "glob": "^11.1.0",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "postcss-nested": "^7.0.2",
    "react-refresh": "^0.16.0",
    "style-loader": "^4.0.0",
    "typescript": "^5.9.3",
    "webpack-merge": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "globals": "^16.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0",
    "typescript-eslint": "^8.62.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "exports": {
    "./config": {
      "types": "./src/config.d.ts",
      "default": "./src/config.js"
    },
    "./navigation": {
      "types": "./src/components/navigation.d.ts",
      "default": "./src/components/navigation.jsx"
    },
    "./head": {
      "types": "./src/components/head.d.ts",
      "default": "./src/components/head.jsx"
    },
    "./redirect": {
      "types": "./src/runtime/redirect.d.ts",
      "default": "./src/runtime/redirect.js"
    }
  }
