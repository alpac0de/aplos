{
  "name": "aplosjs",
  "version": "0.15.0",
  "description": "A fast, modern React framework",
  "author": "Mbechezi Nawo",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/alpac0de/aplos.git"
  },
  "bugs": {
    "url": "https://github.com/alpac0de/aplos/issues"
  },
