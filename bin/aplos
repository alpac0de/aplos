#!/usr/bin/env node

import { config } from "dotenv";
import { existsSync, readFileSync } from "node:fs";
import { resolve, dirname } from "node:path";
import { fileURLToPath } from "node:url";

const projectDir = process.cwd();
config({ path: resolve(projectDir, ".env"), quiet: true });
if (existsSync(resolve(projectDir, ".env.local"))) {
  config({ path: resolve(projectDir, ".env.local"), override: true, quiet: true });
}

import { Command } from "commander";
import devServer from "../src/command/devServer.js";
import build from "../src/command/build.js";
import router from "../src/command/router.js";
import create from "../src/command/create.js";

// Read from the manifest rather than restating it: the hardcoded string had drifted
// to 0.14.0 while the package was 0.15.0, so `aplos --version` reported a version
// that was never published.
const manifest = JSON.parse(
  readFileSync(resolve(dirname(fileURLToPath(import.meta.url)), "../package.json"), "utf8")
);

const program = new Command();
program.name("Aplos").description("React Framework").version(manifest.version);

program
  .command("server")
  .description("Split a string into substrings and display as an array")
  .action(devServer);

program
  .command("build")
  .description("Build assets")
  .option(
    "--mode <mode>",
    "Providing the mode configuration option tells webpack to use its built-in optimizations accordingly",
    process.env.NODE_ENV || "development"
  )
  .option(
    "--static",
    "Pre-render each static route to HTML (SSG). Dynamic routes fall back to SPA.",
    false
  )
  .option(
    "--out-dir <dir>",
    "Directory the build is emitted to, relative to the project root (default: dist, or $APLOS_OUT_DIR)."
  )
  .action(build);

program
  .command("router:debug")
  .argument("[name]", "Name of the route")
  .description("Debug the router")
  .action(router);

program
  .command("router:match")
  .argument("<url>", "URL to test against routes")
  .description("Test if a URL matches any route")
  .action((url) => router({ url }));

program
  .command("create")
  .argument("<project-name>", "Name of the new project")
  .description("Scaffold a new Aplos project")
  .action(create);

program.parse();
