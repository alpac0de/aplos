{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./src/*"],
      "aplos/config": ["./node_modules/aplosjs/src/config"],
      "aplos/navigation": ["./node_modules/aplosjs/src/components/navigation"],
      "aplos/head": ["./node_modules/aplosjs/src/components/head"],
      "aplos/redirect": ["./node_modules/aplosjs/src/runtime/redirect"]
    }
  },
  "include": ["src"]
}
